{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSXA Desktop",
  "version": "0.1.0",
  "identifier": "com.deepinstinct.dsxa.client",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DSXA Desktop",
        "width": 980,
        "height": 900,
        "minWidth": 860,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon_mac_squircle_1024.png",
      "icons/icon_mac_squircle_512.png",
      "icons/icon_1024x1024.png",
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon_512x512.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
