{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DSXA Desktop",
  "version": "0.1.0",
  "identifier": "com.deepinstinct.dsxa.client",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../web"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "DSXA Desktop",
        "width": 980,
        "height": 900,
        "minWidth": 860,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
