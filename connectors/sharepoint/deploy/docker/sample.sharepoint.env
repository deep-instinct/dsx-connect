# Env for SharePoint connector. Pin the image and set tenant/app creds + asset/filter.
# Copy to .env.sharepoint.<env> and use with --env-file.

# SharePoint connector env (sample)
SHAREPOINT_IMAGE=dsxconnect/sharepoint-connector:0.3.40
SHAREPOINT_PORT=8640
SHAREPOINT_WORKERS=1

SP_TENANT_ID=
SP_CLIENT_ID=
SP_CLIENT_SECRET=
SP_VERIFY_TLS=true
SP_CA_BUNDLE=

DSXCONNECTOR_ASSET=your-site/your-library
DSXCONNECTOR_FILTER=
DSXCONNECTOR_ITEM_ACTION=nothing
DSXCONNECTOR_ITEM_ACTION_MOVE_METAINFO=dsxconnect-quarantine
DSXCONNECTOR_DATA_DIR=/app/data

DSXCONNECTOR_CONNECTOR_URL=http://sharepoint-connector:8640
DSXCONNECTOR_DSX_CONNECT_URL=http://dsx-connect-api:8586
DSXCONNECTOR_AUTH__ENABLED=false

# Optional when DSX-Connect auth is enabled
#DSXCONNECT_ENROLLMENT_TOKEN=abc123

# Optional shared knobs
LOG_LEVEL=debug
PYTHONUNBUFFERED=1
DSX_DOCKER_NETWORK=dsx-connect-network
