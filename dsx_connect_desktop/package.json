{
  "name": "dsx-connect-desktop",
  "productName": "DSX-Connect Desktop",
  "version": "0.8.1",
  "private": true,
  "description": "Electron launcher that hosts DSX-Connect Core components, web UI and Connectors",
  "homepage": "https://github.com/deep-instinct/dsx-connect",
  "author": {
    "name": "Deep Instinct",
    "email": "support@deepinstinct.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "node ./scripts/run-electron.js",
    "dev": "node ./scripts/run-electron.js",
    "start:modern": "node ./scripts/run-electron.js --modern",
    "start:intel": "node ./scripts/run-electron.js --intel",
    "build:mac:dir": "electron-builder --mac dir --publish never",
    "start:mac:app": "open \"dist/mac/DSX-Connect Desktop.app\"",
    "security:audit": "./scripts/npm_audit_check.sh",
    "build:mac": "electron-builder --mac --publish never",
    "build:mac:x64": "electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "electron-builder --mac --arm64 --publish never",
    "build:win": "electron-builder --win nsis --publish never",
    "build:linux": "electron-builder --linux AppImage deb --publish never"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.deepinstinct.dsxconnect.desktop",
    "productName": "DSX-Connect Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../connectors",
        "to": "connectors",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/tests/**",
          "!**/.dev.env"
        ]
      },
      {
        "from": "../dsx_connect",
        "to": "dsx_connect",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**"
        ]
      },
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/tests/**"
        ]
      },
      {
        "from": "../dsx_connect_sdk",
        "to": "dsx_connect_sdk",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**"
        ]
      },
      {
        "from": "../dsxa_sdk_py",
        "to": "dsxa_sdk_py",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/*.pyc",
          "!**/.pytest_cache/**",
          "!**/tests/**"
        ]
      },
      {
        "from": "../LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "../NOTICE.md",
        "to": "NOTICE.md"
      }
    ],
    "mac": {
      "icon": "build/icons/dsx-connect-desktop.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "icon": "build/icons/dsx-connect-desktop.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "icon": "build/icons",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Deep Instinct <support@deepinstinct.com>"
    }
  }
}
