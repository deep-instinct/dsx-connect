{
  "name": "dsxa-desktop-electron",
  "productName": "DSXA Desktop",
  "version": "0.1.0",
  "private": true,
  "description": "Independent Electron desktop client for DSXA using the JavaScript SDK",
  "homepage": "https://github.com/deep-instinct/dsx-connect",
  "author": {
    "name": "Deep Instinct",
    "email": "support@deepinstinct.com"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build:mac": "electron-builder --mac --publish never",
    "build:mac:x64": "electron-builder --mac --x64 --publish never",
    "build:mac:arm64": "electron-builder --mac --arm64 --publish never",
    "build:win": "electron-builder --win nsis --publish never",
    "build:linux": "electron-builder --linux AppImage deb --publish never"
  },
  "dependencies": {
    "@deep-instinct/dsxa-sdk-js": "file:../dsxa_sdk_js"
  },
  "devDependencies": {
    "electron": "^41.0.4",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.deepinstinct.dsxa.desktop.electron",
    "productName": "DSXA Desktop",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "index.html",
      "style.css",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../LICENSE",
        "to": "LICENSE"
      },
      {
        "from": "../NOTICE.md",
        "to": "NOTICE.md"
      }
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.developer-tools"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Deep Instinct <support@deepinstinct.com>"
    }
  }
}
