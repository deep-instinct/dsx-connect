FROM python:3.12-slim

WORKDIR /workspace

COPY dsxa_sdk_py /workspace/dsxa_sdk_py
COPY dsx_transfer /workspace/dsx_transfer
COPY dsx_transfer/examples/sftpgo/dsx-transfer-entrypoint.sh /usr/local/bin/dsx-transfer-entrypoint

RUN python -m pip install --no-cache-dir -e /workspace/dsxa_sdk_py -e /workspace/dsx_transfer
RUN chmod +x /usr/local/bin/dsx-transfer-entrypoint

EXPOSE 8088

CMD ["dsx-transfer-entrypoint"]
