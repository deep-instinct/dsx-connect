# Env for AWS S3 connector. Pin the image and set AWS creds + asset/filter. Copy to .env.aws-s3.<env> and use with --env-file.

# AWS S3 connector env (sample)
AWS_S3_IMAGE=dsxconnect/aws-s3-connector:0.5.45
AWS_S3_PORT=8600
AWS_S3_WORKERS=1

# Connector environment mode: dev | stg | prod
DSXCONNECTOR_APP_ENV=dev

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

DSXCONNECTOR_ASSET=your-bucket
DSXCONNECTOR_FILTER=
DSXCONNECTOR_ITEM_ACTION=nothing
DSXCONNECTOR_ITEM_ACTION_MOVE_METAINFO=dsxconnect-quarantine
DSXCONNECTOR_DATA_DIR=/app/data

DSXCONNECTOR_CONNECTOR_URL=http://aws-s3-connector:8600
DSXCONNECTOR_DSX_CONNECT_URL=http://dsx-connect-api:8586
DSXCONNECTOR_AUTH__ENABLED=false

# Optional when DSX-Connect auth is enabled
#DSXCONNECT_ENROLLMENT_TOKEN=abc123

# Optional shared knobs
LOG_LEVEL=debug
PYTHONUNBUFFERED=1
DSX_DOCKER_NETWORK=dsx-connect-network

# Local-only UI config persistence (effective when DSXCONNECTOR_ENV_FILE points under ~/.dsx-connect-local)
DSXCONNECTOR_CONFIG_PERSIST_LOCAL_ONLY=true
